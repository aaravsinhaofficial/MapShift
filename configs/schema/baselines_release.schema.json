{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mapshift.local/schemas/baselines_release.schema.json",
  "title": "MapShift Baseline Release Config",
  "type": "object",
  "required": ["schema_version", "fairness", "system_families", "sanity_baselines", "seed_counts"],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "fairness": {
      "type": "object",
      "required": [
        "match_exploration_budget",
        "shared_validation_protocol",
        "freeze_hparams_before_test",
        "report_compute_and_params"
      ],
      "properties": {
        "match_exploration_budget": { "type": "boolean" },
        "shared_validation_protocol": { "type": "boolean" },
        "freeze_hparams_before_test": { "type": "boolean" },
        "report_compute_and_params": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "system_families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "enabled", "category", "notes"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "enabled": { "type": "boolean" },
          "category": { "type": "string", "minLength": 1 },
          "notes": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "sanity_baselines": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "seed_counts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "integer", "minimum": 1 }
    }
  },
  "additionalProperties": false
}
